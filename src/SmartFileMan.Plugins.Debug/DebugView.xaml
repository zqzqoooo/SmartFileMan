<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartFileMan.Plugins.Debug.DebugView"
             BackgroundColor="Black">
    <Grid RowDefinitions="Auto, *">
        <!-- Tab Header -->
        <HorizontalStackLayout Grid.Row="0" Spacing="10" Padding="5">
            <Button Text="Console" Clicked="OnTabConsoleClicked" x:Name="BtnConsole" BackgroundColor="#333" TextColor="White" />
            <Button Text="Simulator" Clicked="OnTabSimulatorClicked" x:Name="BtnSimulator" BackgroundColor="Transparent" TextColor="Gray" />
            <Button Text="API Tester" Clicked="OnTabApiClicked" x:Name="BtnApi" BackgroundColor="Transparent" TextColor="Gray" />
            <Button Text="Storage" Clicked="OnTabStorageClicked" x:Name="BtnStorage" BackgroundColor="Transparent" TextColor="Gray" />
        </HorizontalStackLayout>

        <!-- Tab Content -->
        
        <!-- Console View -->
        <Grid Grid.Row="1" x:Name="ViewConsole" RowDefinitions="Auto, Auto, *, Auto" Padding="10" RowSpacing="10">
             <!-- (Existing Console Content) -->
            <Label Grid.Row="0" Text="Real-time Execution Logs" TextColor="#00FF00" FontAttributes="Bold" />
             
             <!-- Log List -->
            <CollectionView Grid.Row="2" x:Name="LogList" ItemsSource="{Binding Logs}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="80, 50, 60, *" Padding="0,2">
                            <Label Grid.Column="0" Text="{Binding DisplayTime}" TextColor="Gray" FontSize="11" />
                            <Label Grid.Column="1" Text="{Binding Category}" TextColor="Silver" FontSize="11" FontAttributes="Bold"/>
                            <Label Grid.Column="2" Text="{Binding Code}" TextColor="{Binding DisplayColor}" FontSize="11" />
                            <Label Grid.Column="3" Text="{Binding Message}" TextColor="{Binding DisplayColor}" FontSize="11" LineBreakMode="WordWrap"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <HorizontalStackLayout Grid.Row="3" Spacing="10">
                <Button Text="Clear Logs" Clicked="OnClearClicked" BackgroundColor="#333" TextColor="White"/>
            </HorizontalStackLayout>
        </Grid>

        <!-- Simulator View -->
        <Grid Grid.Row="1" x:Name="ViewSimulator" IsVisible="False" RowDefinitions="Auto, *, Auto" Padding="10" RowSpacing="10">
            <VerticalStackLayout Grid.Row="0" Spacing="10">
                <Label Text="Bidding Arena (Dry Run)" TextColor="#FFD700" FontAttributes="Bold" FontSize="18" />
                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="5">
                    <Entry x:Name="SimFileEntry" Placeholder="Select a file to bid on..." TextColor="White" IsReadOnly="True" />
                    <Button Text="Browse" Clicked="OnPickFileClicked" BackgroundColor="#512BD4" TextColor="White" Grid.Column="1"/>
                </Grid>
                <Button Text="Run Bidding Simulation" Clicked="OnProcessClicked" BackgroundColor="#2B0B98" TextColor="White" />
            </VerticalStackLayout>
            
            <CollectionView Grid.Row="1" x:Name="BiddingResultsList" ItemsSource="{Binding BiddingResults}">
                <CollectionView.Header>
                     <Grid ColumnDefinitions="120, 80, 60, *" BackgroundColor="#222" Padding="5">
                        <Label Text="Plugin" TextColor="White" FontAttributes="Bold"/>
                        <Label Grid.Column="1" Text="Score" TextColor="White" FontAttributes="Bold"/>
                        <Label Grid.Column="2" Text="Time" TextColor="White" FontAttributes="Bold"/>
                        <Label Grid.Column="3" Text="Proposal" TextColor="White" FontAttributes="Bold"/>
                     </Grid>
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="5" Margin="0,2" BackgroundColor="#111" BorderColor="Gray">
                            <Grid ColumnDefinitions="120, 80, 60, *">
                                <Label Text="{Binding PluginName}" TextColor="{Binding NameColor}" VerticalOptions="Center"/>
                                <Label Grid.Column="1" Text="{Binding ScoreDisplay}" TextColor="{Binding ScoreColor}" FontAttributes="Bold" VerticalOptions="Center"/>
                                <Label Grid.Column="2" Text="{Binding DurationMs}" TextColor="Gray" FontSize="11" VerticalOptions="Center"/>
                                <Label Grid.Column="3" Text="{Binding ProposalDetails}" TextColor="Silver" FontSize="11" LineBreakMode="WordWrap" VerticalOptions="Center"/>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <!-- API Tester View -->
        <Grid Grid.Row="1" x:Name="ViewApiTester" IsVisible="False" RowDefinitions="Auto, Auto, Auto, *" Padding="10" RowSpacing="15">
            <Label Grid.Row="0" Text="API Capability Tester" TextColor="#00FFFF" FontAttributes="Bold" FontSize="18" />
            
            <!-- File Status -->
            <Border Grid.Row="1" Stroke="Gray" BackgroundColor="#111" Padding="10">
                <VerticalStackLayout Spacing="5">
                    <Label Text="Current Test File Subject:" TextColor="Gray" FontSize="12"/>
                    <Label x:Name="LblTestFile" Text="No file selected/created" TextColor="White" LineBreakMode="CharacterWrap"/>
                    <Button Text="Create New Test File" Clicked="OnCreateTestFileClicked" BackgroundColor="#006400" TextColor="White" FontSize="12" HorizontalOptions="Start"/>
                </VerticalStackLayout>
            </Border>

            <!-- Actions -->
            <VerticalStackLayout Grid.Row="2" Spacing="10">
                <Label Text="Operations (SafeContext Wrapper)" TextColor="Silver" FontAttributes="Bold"/>
                
                <Grid ColumnDefinitions="*, *, *" ColumnSpacing="10">
                    <!-- Rename -->
                    <Button Grid.Column="0" Text="Rename" Clicked="OnTestRenameClicked" BackgroundColor="#444" TextColor="White"/>
                    
                    <!-- Move -->
                    <Button Grid.Column="1" Text="Move" Clicked="OnTestMoveClicked" BackgroundColor="#444" TextColor="White"/>
                    
                    <!-- Delete -->
                    <Button Grid.Column="2" Text="Delete" Clicked="OnTestDeleteClicked" BackgroundColor="#8B0000" TextColor="White"/>
                </Grid>
            </VerticalStackLayout>

            <!-- Output Log specific to API -->
             <ScrollView Grid.Row="3" BackgroundColor="#050505" Padding="5">
                <VerticalStackLayout>
                    <Label x:Name="LblApiOutput" Text="Output will appear here..." TextColor="Lime" FontSize="12"/>
                    
                    <BoxView HeightRequest="1" Color="Gray" Margin="0,10"/>
                    <Label Text="File Metadata Inspector" TextColor="#00FFFF" FontAttributes="Bold" />
                    
                    <!-- Metadata Grid -->
                    <Grid x:Name="MetadataGrid" ColumnDefinitions="150, *" RowDefinitions="Auto" RowSpacing="2">
                        <!-- Header -->
                        <Label Grid.Row="0" Grid.Column="0" Text="Property" TextColor="Silver" FontAttributes="Bold"/>
                        <Label Grid.Row="0" Grid.Column="1" Text="Value" TextColor="Silver" FontAttributes="Bold"/>
                    </Grid>
                    <CollectionView ItemsSource="{Binding MetadataItems}" HeightRequest="200">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="150, *" Padding="0,2">
                                    <Label Grid.Column="0" Text="{Binding Key}" TextColor="Gray" FontSize="12"/>
                                    <Label Grid.Column="1" Text="{Binding Value}" TextColor="White" FontSize="12" LineBreakMode="TailTruncation"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>

        <!-- Storage View -->
        <Grid Grid.Row="1" x:Name="ViewStorage" IsVisible="False" RowDefinitions="Auto, Auto, Auto, *" Padding="10" RowSpacing="10">
            <Label Grid.Row="0" Text="Plugin Storage Inspector" TextColor="#FF00FF" FontAttributes="Bold" FontSize="18" />
            
            <HorizontalStackLayout Grid.Row="1" Spacing="10">
                <Picker x:Name="PluginPicker" Title="Select Plugin" TextColor="White" TitleColor="Gray" WidthRequest="250" BackgroundColor="#222" />
                <Button Text="Inspect Storage" Clicked="OnInspectStorageClicked" BackgroundColor="#512BD4" TextColor="White" />
            </HorizontalStackLayout>
            
            <Grid Grid.Row="2" ColumnDefinitions="*, Auto" ColumnSpacing="10">
                <Entry x:Name="SqlEntry" Placeholder="SQL Query (e.g. SELECT $ FROM file_tracker)" BackgroundColor="#222" TextColor="White" />
                <Button Grid.Column="1" Text="Run SQL" Clicked="OnRunSqlClicked" BackgroundColor="#006400" TextColor="White" />
            </Grid>

            <Editor Grid.Row="3" x:Name="StorageOutput" IsReadOnly="True" BackgroundColor="#111" TextColor="#00FF00" Placeholder="JSON Dump will appear here..." />
        </Grid>

    </Grid>
</ContentView>
