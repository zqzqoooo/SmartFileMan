<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:SmartFileMan.App"
             x:Class="SmartFileMan.App.MainPage"
             Title="SmartFileMan"
             BackgroundColor="{AppThemeBinding Light=#F3F3F3, Dark=#121212}">

    <Grid>
        <!-- Background Info -->
        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10">
            <Label Text="SmartFileMan" 
                   FontSize="40" 
                   FontAttributes="Bold" 
                   TextColor="{AppThemeBinding Light=#E0E0E0, Dark=#333}" 
                   HorizontalOptions="Center" />
            <Label Text="v1.0.0" 
                   FontSize="16" 
                   TextColor="{AppThemeBinding Light=#CCCCCC, Dark=#444}" 
                   HorizontalOptions="Center" 
                   FontFamily="Consolas"/>
        </VerticalStackLayout>
    </Grid>

</ContentPage>