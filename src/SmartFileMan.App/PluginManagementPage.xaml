<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartFileMan.App.PluginManagementPage"
             Title="插件管理">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="已安装插件" FontSize="18" FontAttributes="Bold" />
            <Label Text="在这里启用、禁用或重新排序插件" FontSize="12" TextColor="Gray" />

            <CollectionView x:Name="PluginsList" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="10" Margin="0,5" BorderColor="LightGray">
                            <Grid ColumnDefinitions="*, Auto, Auto, Auto">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{Binding DisplayName}" FontAttributes="Bold" />
                                    <Label Text="{Binding Description}" FontSize="12" TextColor="Gray" />
                                    <Label Text="{Binding Version, StringFormat='v{0}'}" FontSize="10" TextColor="Silver" />
                                </VerticalStackLayout>

                                <Switch Grid.Column="1" IsToggled="{Binding IsEnabled}" Toggled="OnPluginToggled" />
                                
                                <Button Grid.Column="2" Text="↑" Clicked="OnMoveUpClicked" 
                                        BackgroundColor="Transparent" TextColor="Black" WidthRequest="40" />
                                <Button Grid.Column="3" Text="↓" Clicked="OnMoveDownClicked" 
                                        BackgroundColor="Transparent" TextColor="Black" WidthRequest="40" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>