<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:SmartFileMan.Contracts;assembly=SmartFileMan.Contracts"
             x:Class="SmartFileMan.App.SettingsPage"
             Title="Settings"
             BackgroundColor="{AppThemeBinding Light=#F3F3F3, Dark=#121212}">

    <Grid RowDefinitions="Auto, *">
        <!-- 1. Top Navigation Bar (Segmented Control Style) -->
        <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Grid.Row="0" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
            <HorizontalStackLayout Spacing="10" Padding="15,10">
                <Button Text="🧩 Ecosystem" x:Name="BtnTabPlugins" Clicked="OnTabClicked" 
                        CornerRadius="20" HeightRequest="40" Padding="15,0"
                        BackgroundColor="#512BD4" TextColor="White" />
                
                <Button Text="⚙️ Automation" x:Name="BtnTabAutomation" Clicked="OnTabClicked" 
                        CornerRadius="20" HeightRequest="40" Padding="15,0"
                        BackgroundColor="Transparent" TextColor="Gray" />
                
                <Button Text="🛡️ Security" x:Name="BtnTabData" Clicked="OnTabClicked" 
                        CornerRadius="20" HeightRequest="40" Padding="15,0"
                        BackgroundColor="Transparent" TextColor="Gray" />
                
                <Button Text="👨‍💻 Developer" x:Name="BtnTabDev" Clicked="OnTabClicked" 
                        CornerRadius="20" HeightRequest="40" Padding="15,0"
                        BackgroundColor="Transparent" TextColor="Gray" />
            </HorizontalStackLayout>
        </ScrollView>

        <!-- 2. Content Sections -->
        <Grid Grid.Row="1" Padding="0">
            
            <!-- SECTION: PLUGIN ECOSYSTEM -->
            <ScrollView x:Name="SecPlugins" IsVisible="True" Padding="15">
                <VerticalStackLayout Spacing="20">
                    <!-- Installed Plugins Header -->
                    <Label Text="Installed Plugins" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#333, Dark=White}"/>
                    <Label Text="Manage plugins and their priority order. Top plugins bid first (if Specific)." FontSize="12" TextColor="Gray" Margin="0,-10,0,0"/>

                    <!-- Plugin List -->
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Plugins}" Spacing="10">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:IPlugin">
                                <Border StrokeShape="RoundRectangle 10" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=White, Dark=#252525}" Padding="15">
                                    <Grid ColumnDefinitions="Auto, *, Auto, Auto" RowDefinitions="Auto, Auto">
                                        <!-- Icon placeholder -->
                                        <Label Text="📦" FontSize="20" VerticalOptions="Center" Margin="0,0,10,0" />
                                        
                                        <!-- Info -->
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                            <Label Text="{Binding DisplayName}" FontAttributes="Bold" FontSize="15"/>
                                            <Label Text="{Binding Description}" FontSize="11" TextColor="Gray" LineBreakMode="TailTruncation"/>
                                            <HorizontalStackLayout Spacing="5">
                                                <Label Text="{Binding Version, StringFormat='v{0}'}" FontSize="10" TextColor="{AppThemeBinding Light=#512BD4, Dark=#BB86FC}"/>
                                                <Label Text="•" FontSize="10" TextColor="Gray"/>
                                                <Label Text="{Binding Id}" FontSize="10" TextColor="Gray"/>
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>

                                        <!-- Priority Controls -->
                                        <VerticalStackLayout Grid.Column="2" Spacing="0" VerticalOptions="Center" Margin="5,0">
                                            <Button Text="▲" Clicked="OnMoveUpClicked" CommandParameter="{Binding .}"
                                                    BackgroundColor="Transparent" TextColor="Gray" HeightRequest="30" Padding="0" FontSize="10"/>
                                            <Button Text="▼" Clicked="OnMoveDownClicked" CommandParameter="{Binding .}"
                                                    BackgroundColor="Transparent" TextColor="Gray" HeightRequest="30" Padding="0" FontSize="10"/>
                                        </VerticalStackLayout>
                                        
                                        <!-- Controls -->
                                        <HorizontalStackLayout Grid.Column="3" VerticalOptions="Center" Spacing="5">
                                             <Switch IsToggled="{Binding IsEnabled}" Toggled="OnPluginToggled" />
                                             <Button Text="🗑️" 
                                                     Clicked="OnDeletePluginClicked" 
                                                     CommandParameter="{Binding .}"
                                                     BackgroundColor="Transparent" 
                                                     TextColor="Red" 
                                                     FontSize="14"
                                                     Padding="0"
                                                     WidthRequest="40"/>
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                    
                    <Label Text="No plugins found." IsVisible="{Binding Plugins.Count, Converter={StaticResource InvertedBoolConverter}}" HorizontalOptions="Center" TextColor="Gray"/>
                </VerticalStackLayout>
            </ScrollView>

            <!-- SECTION: AUTOMATION ENGINE -->
            <ScrollView x:Name="SecAutomation" IsVisible="False" Padding="15">
                <VerticalStackLayout Spacing="25">
                    
                    <!-- Watch Folders -->
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Monitor Folders" FontSize="18" FontAttributes="Bold" />
                        <Label Text="SmartFileMan will automatically organize files dropped here." FontSize="12" TextColor="Gray" />
                        
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding WatchedFolders}" Spacing="8">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border StrokeShape="RoundRectangle 8" BackgroundColor="{AppThemeBinding Light=White, Dark=#252525}" Padding="10">
                                        <Grid ColumnDefinitions="Auto, *, Auto">
                                            <Label Text="📂" VerticalOptions="Center" Margin="0,0,10,0"/>
                                            <Label Grid.Column="1" Text="{Binding .}" VerticalOptions="Center" LineBreakMode="MiddleTruncation" />
                                            <Button Grid.Column="2" Text="Remove" Clicked="OnRemoveWatchClicked" CommandParameter="{Binding .}"
                                                    BackgroundColor="#20FF0000" TextColor="Red" FontSize="11" CornerRadius="5" HeightRequest="30" Padding="10,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                        
                        <Button Text="+ Add Folder" Clicked="OnAddWatchClicked" 
                                HorizontalOptions="Fill" BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#333}" TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E0E0E0, Dark=#333}" />

                    <!-- Global Ignore List -->
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Global Ignore List" FontSize="18" FontAttributes="Bold" />
                        <Label Text="Files with these extensions will be skipped." FontSize="12" TextColor="Gray" />
                        
                        <FlexLayout BindableLayout.ItemsSource="{Binding IgnoredExtensions}" Wrap="Wrap" JustifyContent="Start" AlignItems="Center">
                             <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border StrokeShape="RoundRectangle 15" BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#333}" Padding="10,5" Margin="0,0,5,5">
                                        <HorizontalStackLayout Spacing="5">
                                            <Label Text="{Binding .}" FontSize="12" VerticalOptions="Center"/>
                                            <Label Text="✕" TextColor="Red" FontSize="12" VerticalOptions="Center">
                                                <Label.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnRemoveExtClicked" CommandParameter="{Binding .}"/>
                                                </Label.GestureRecognizers>
                                            </Label>
                                        </HorizontalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </FlexLayout>

                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                            <Entry x:Name="ExtEntry" Placeholder=".tmp" ReturnType="Done" Completed="OnAddExtClicked" />
                            <Button Grid.Column="1" Text="Add" Clicked="OnAddExtClicked" />
                        </Grid>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </ScrollView>

            <!-- SECTION: DATA & SECURITY -->
            <ScrollView x:Name="SecSecurity" IsVisible="False" Padding="15">
                <VerticalStackLayout Spacing="25">
                    
                    <!-- Plugin Storage -->
                    <Border StrokeShape="RoundRectangle 10" BackgroundColor="{AppThemeBinding Light=White, Dark=#252525}" Padding="15">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Plugin Storage" FontAttributes="Bold" FontSize="16"/>
                            <Label Text="Manage data stored by plugins (database, cache)." FontSize="12" TextColor="Gray"/>

                            <Button Text="Clear All Data" BackgroundColor="#20FF0000" TextColor="Red" Clicked="OnClearDataClicked" Margin="0,10,0,0"/>
                            <Button Text="Open Data Folder" Clicked="OnOpenDataFolderClicked" BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#333}" TextColor="{AppThemeBinding Light=Black, Dark=White}" Margin="0,10,0,0"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Undo Stack -->
                     <Border StrokeShape="RoundRectangle 10" BackgroundColor="{AppThemeBinding Light=White, Dark=#252525}" Padding="15">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Undo History" FontAttributes="Bold" FontSize="16"/>
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="Max Undo Steps:" VerticalOptions="Center"/>
                                <Entry Text="50" Keyboard="Numeric" WidthRequest="60" 
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                       BackgroundColor="Transparent"
                                       Completed="OnUndoStepsCompleted" 
                                       Unfocused="OnUndoStepsCompleted" 
                                       HorizontalTextAlignment="Center"/>
                            </Grid>
                            <Button Text="Undo Last Action" Clicked="OnUndoClicked"
                                    BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#333}" 
                                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                    HorizontalOptions="Fill" Margin="0,5,0,0"/>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>

            <!-- SECTION: DEVELOPER LAB -->
            <ScrollView x:Name="SecDeveloper" IsVisible="False" Padding="15">
                <VerticalStackLayout Spacing="20">
                    <Label Text="Developer Lab" FontSize="20" FontAttributes="Bold" />
                    <Label Text="Tools for plugin developers." TextColor="Gray" Margin="0,-10,0,0"/>
                    
                    <!-- Dev Mode -->
                    <Border StrokeShape="RoundRectangle 10" BackgroundColor="{AppThemeBinding Light=White, Dark=#252525}" Padding="15">
                         <Grid ColumnDefinitions="*, Auto">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="Developer Mode" FontAttributes="Bold"/>
                                <Label Text="Allow loading unsigned plugins from /Plugins folder." FontSize="11" TextColor="Gray"/>
                            </VerticalStackLayout>
                            <Switch Grid.Column="1" x:Name="DevModeSwitch" Toggled="OnDevModeToggled" />
                        </Grid>
                    </Border>
                    
                    <!-- Logs -->
                    <Border StrokeShape="RoundRectangle 10" BackgroundColor="{AppThemeBinding Light=White, Dark=#252525}" Padding="15">
                         <VerticalStackLayout Spacing="10">
                            <Label Text="Logs &amp; Diagnostics" FontAttributes="Bold"/>
                             <Button Text="Open Log Folder" Clicked="OnOpenLogFolderClicked" 
                                     BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#333}" TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Shortcuts -->
                    <Border x:Name="GrpDebugShortcuts" StrokeShape="RoundRectangle 10" BackgroundColor="{AppThemeBinding Light=White, Dark=#252525}" Padding="15">
                         <VerticalStackLayout Spacing="10">
                            <Label Text="Shortcuts" FontAttributes="Bold"/>
                             <Button Text="Launch Debug Plugin" Clicked="OnLaunchDebugClicked" 
                                     BackgroundColor="#512BD4" TextColor="White"/>
                             <Label Text="* Requires 'com.smartfileman.debug' plugin installed." FontSize="10" TextColor="Gray" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>

    <ContentPage.Resources>
        <ResourceDictionary>
             <models:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>
</ContentPage>