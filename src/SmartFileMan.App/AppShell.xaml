<Shell
    x:Class="SmartFileMan.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SmartFileMan.App"
    Title="SmartFileMan"
    FlyoutBehavior="Flyout"
    FlyoutBackgroundColor="{AppThemeBinding Light=#f0f0f0, Dark=#1f1f1f}">

    <!-- Top Part: Dynamic Plugin List will be added here by C# code -->
    <!-- The "FlyoutHeader" is removed as per request to move title to Settings page -->

    <!-- FlyoutFooter for Settings and Exit -->
    <Shell.FlyoutFooter>
        <VerticalStackLayout BackgroundColor="{AppThemeBinding Light=#e0e0e0, Dark=#2d2d2d}">
            <Grid Padding="15" ColumnDefinitions="40, *">
                <Image Source="dotnet_bot.png" HeightRequest="24" VerticalOptions="Center" />
                <Label Grid.Column="1" Text="Settings" VerticalOptions="Center" FontSize="16" />
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSettingsClicked" />
                </Grid.GestureRecognizers>
            </Grid>
            <BoxView HeightRequest="1" Color="{AppThemeBinding Light=Gray, Dark=#404040}" />
            <Grid Padding="15" ColumnDefinitions="40, *">
                <Image Source="dotnet_bot.png" HeightRequest="24" VerticalOptions="Center" />
                <Label Grid.Column="1" Text="Exit" VerticalOptions="Center" FontSize="16" />
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnExitClicked" />
                </Grid.GestureRecognizers>
            </Grid>
        </VerticalStackLayout>
    </Shell.FlyoutFooter>

</Shell>