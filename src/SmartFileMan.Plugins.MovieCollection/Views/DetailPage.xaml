<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SmartFileMan.Plugins.MovieCollection.ViewModels"
             x:Class="SmartFileMan.Plugins.MovieCollection.Views.DetailPage">

    <ContentView.Resources>
        <Style x:Key="TitleLabelStyle" TargetType="Label">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="TextColor" Value="#FFFFFF"/>
        </Style>

        <Style x:Key="SubtitleLabelStyle" TargetType="Label">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="TextColor" Value="#B0B0B0"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="Label">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="TextColor" Value="#FFFFFF"/>
            <Setter Property="Margin" Value="0,16,0,8"/>
        </Style>

        <Style x:Key="CardBackgroundStyle" TargetType="Frame">
            <Setter Property="BackgroundColor" Value="#16213E"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
    </ContentView.Resources>

    <Grid BackgroundColor="#1A1A2E">
        <!-- 加载状态 -->
        <Frame IsVisible="{Binding IsLoading}"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               BackgroundColor="#16213E"
               CornerRadius="12"
               Padding="24">
            <StackLayout>
                <ActivityIndicator Color="#E94560" IsRunning="True"/>
                <Label Text="加载中..." 
                       TextColor="#B0B0B0" 
                       Margin="0,8,0,0"
                       HorizontalOptions="Center"/>
            </StackLayout>
        </Frame>

        <!-- 主内容 -->
        <ScrollView>
            <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">

                <!-- 返回按钮 -->
                <Button Text="🔙 返回海报墙"
                        Command="{Binding GoBackCommand}"
                        HorizontalOptions="Start"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        Margin="16,16,0,0" />

                <!-- 头部信息 -->
                <Grid Grid.Row="1" ColumnDefinitions="150,*" Margin="16">
                    <Frame CornerRadius="8" 
                           BackgroundColor="#16213E" 
                           Padding="0"
                           HasShadow="False">
                        <Image Source="{Binding PosterDataUrl}"
                               WidthRequest="150"
                               HeightRequest="225"
                               Aspect="AspectFill"/>
                    </Frame>

                    <VerticalStackLayout Grid.Column="1" Margin="16,0,0,0" Spacing="4">
                        <Label Text="{Binding MediaInfo.Title}"
                               Style="{StaticResource TitleLabelStyle}"/>

                        <Label Text="{Binding MediaInfo.OriginalTitle}"
                               Style="{StaticResource SubtitleLabelStyle}"/>

                        <HorizontalStackLayout Margin="0,8,0,0">
                            <Label Text="⭐ " FontSize="14" TextColor="#E94560"/>
                            <Label Text="{Binding MediaInfo.VoteAverage, StringFormat='{}{0:F1}'}"
                                   FontSize="14" TextColor="#FFFFFF"/>
                            <Label Text="{Binding MediaInfo.VoteCount, StringFormat=' ({0}+ votes)'}"
                                   FontSize="12" TextColor="#B0B0B0"/>
                        </HorizontalStackLayout>

                        <Label Margin="0,4,0,0" FontSize="12">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="📅 " TextColor="#533483"/>
                                    <Span Text="{Binding MediaInfo.ReleaseDate, StringFormat='{}{0:yyyy-MM-dd}'}"
                                          TextColor="#B0B0B0"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>

                        <Label Margin="0,4,0,0" FontSize="12">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="🏷️ " TextColor="#533483"/>
                                    <Span Text="{Binding MediaInfo.NumberOfSeasons, StringFormat='{}{0}季'}"
                                          TextColor="#B0B0B0"/>
                                    <Span Text=" / " TextColor="#B0B0B0"/>
                                    <Span Text="{Binding MediaInfo.NumberOfEpisodes, StringFormat='{}{0}集'}"
                                          TextColor="#B0B0B0"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>

                        <HorizontalStackLayout Margin="0,8,0,0">
                            <Button Text="查看详情"
                                    BackgroundColor="#E94560"
                                    TextColor="White"
                                    CornerRadius="4"
                                    Padding="12,6"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Grid>

                <!-- 剧情简介 -->
                <VerticalStackLayout Grid.Row="1" Margin="16,0">
                    <Label Text="剧情简介" Style="{StaticResource SectionTitleStyle}"/>
                    <Label Text="{Binding MediaInfo.Overview}"
                           FontSize="14"
                           TextColor="#B0B0B0"
                           LineHeight="1.4"/>
                </VerticalStackLayout>

                <!-- 演员阵容 -->
                <VerticalStackLayout Grid.Row="2" Margin="16,0">
                    <Label Text="演员阵容" Style="{StaticResource SectionTitleStyle}"/>

                    <ScrollView Orientation="Horizontal" Margin="0,8,0,0">
                        <StackLayout Orientation="Horizontal">
                            <Label Text="演员列表加载中..." 
                                   TextColor="#B0B0B0"/>
                        </StackLayout>
                    </ScrollView>
                </VerticalStackLayout>

                <!-- 剧集列表 -->
                <VerticalStackLayout Grid.Row="3" Margin="16,0,16,16">
                    <Label Text="剧集列表" Style="{StaticResource SectionTitleStyle}"/>

                    <!-- 季选择器 -->
                    <ScrollView Orientation="Horizontal" Margin="0,0,0,8">
                        <StackLayout Orientation="Horizontal">
                            <Label Text="季列表加载中..." 
                                   TextColor="#B0B0B0"/>
                        </StackLayout>
                    </ScrollView>

                    <!-- 集列表 -->
                    <ScrollView>
                        <StackLayout>
                            <Label Text="集列表加载中..." 
                                   TextColor="#B0B0B0"/>
                        </StackLayout>
                    </ScrollView>
                </VerticalStackLayout>
            </Grid>
        </ScrollView>

        <!-- 错误消息 -->
        <Frame IsVisible="{Binding ErrorMessage, Converter={StaticResource NullToBoolConverter}}"
               BackgroundColor="#F44336"
               CornerRadius="8"
               Padding="16"
               HorizontalOptions="Center"
               VerticalOptions="Center">
            <Label Text="{Binding ErrorMessage}"
                   TextColor="White"
                   FontSize="14"/>
        </Frame>
    </Grid>
</ContentView>
